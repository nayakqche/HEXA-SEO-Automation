# ───────────────────────────────────────────────────────────────
# HEXA SEO Automation — environment configuration
# Copy this file to `.env` and fill in your keys.
# ───────────────────────────────────────────────────────────────

# Anthropic Claude API key — writes the SEO blogs.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pexels API key — fetches stock photos for hero + in-blog images.
# Get one at https://www.pexels.com/api/  (free — 200 req/hr, 20k req/mo)
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The website the blogs must stay grounded in (prevents hallucination).
# Defaults to Hexa Climate. Change only if you point this at another brand.
BRAND_WEBSITE=https://hexaclimate.com

# Postgres — paste Render's "Internal Database URL" for the linked service.
# Optional: the app runs fine without it (blog generation is stateless);
# set it once you want to persist keyword libraries / run history.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Models (sensible defaults; override only if you know you need to) ──
# Claude model used for blog writing.
CLAUDE_MODEL=claude-sonnet-4-6

# ── Optional tuning ──
# How thoroughly Claude thinks per blog: low | medium | high | max
CLAUDE_EFFORT=high
# Max pages to crawl from the brand site when building grounding context.
MAX_CRAWL_PAGES=12
# How many keywords to generate in parallel (1–8). Higher = faster but more
# API load. 3 is a good balance.
CONCURRENCY=3
# Flask server port.
PORT=5000
